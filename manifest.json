{
  "manifest_version": 3,
  "name": "English Reader",
  "version": "1.0.0",
  "description": "Read English PDFs and EPUBs with sentence-by-sentence translation, TTS, and word definitions powered by ChatGPT API.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["reader.html", "lib/*", "dict-en.json"],
      "matches": ["chrome-extension://*/*"]
    }
  ]
}
